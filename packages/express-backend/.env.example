# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/tldr
# Or Atlas: MONGO_CONNECTION_STRING=mongodb+srv://user:pass@cluster.net/

PORT=8000

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# CORS — frontend origin(s), comma-separated
FRONTEND_URL=https://your-frontend.vercel.app
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Anthropic API (optional but recommended for AI summaries)
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Scraper tuning
MAX_ITEMS_PER_SOURCE=15
MIN_BODY_CHARS_FOR_SUMMARY=250
SCRAPER_REQUEST_TIMEOUT_MS=15000

# Cron expression for scheduled scrape (default: top of every hour)
SCRAPE_CRON=0 * * * *
